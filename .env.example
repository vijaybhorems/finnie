# Copy this to .env and fill in your API keys

# Anthropic (LLM)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Market Data
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here   # https://www.alphavantage.co/support/#api-key

# Macroeconomic Data
FRED_API_KEY=your_fred_api_key_here                  # https://fred.stlouisfed.org/docs/api/api_key.html

# News
NEWS_API_KEY=your_newsapi_key_here                   # https://newsapi.org/register

# Redis (optional override)
REDIS_HOST=localhost
REDIS_PORT=6379

# App
LOG_LEVEL=INFO
DEBUG=false

# Authentication (Google OIDC) — see https://docs.streamlit.io/develop/tutorials/authentication/google
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
AUTH_REDIRECT_URI=http://localhost:8501/oauth2callback
AUTH_COOKIE_SECRET=generate_with_python_c_import_secrets_print_secrets_token_hex_32

# Email allowlist (comma-separated, leave empty to allow all authenticated users)
ALLOWED_EMAILS=alice@gmail.com,bob@company.com
